{
  "name": "geniusclaw-os",
  "version": "1.0.0",
  "description": "GeniusClaw Operation System - P2P AI Operating System",
  "main": "src/index.js",
  "type": "module",
  "scripts": {
    "start": "node src/index.js",
    "dev": "node --watch src/index.js",
    "p2p": "node src/core/p2p-network.js",
    "api": "node src/api/server.js",
    "web": "cd src/web && npm run dev",
    "test": "node --test src/**/*.test.js",
    "build": "npm run build:image",
    "build:image": "docker build -t geniusclaw-os:latest ."
  },
  "keywords": [
    "openclaw",
    "ai",
    "os",
    "p2p",
    "skills"
  ],
  "author": "Benedict Trump",
  "license": "MIT",
  "dependencies": {
    "@libp2p/kad-dht": "^1.0.0",
    "@libp2p/mplex": "^1.0.0",
    "@libp2p/tcp": "^1.0.0",
    "@libp2p/webrtc": "^1.0.0",
    "@libp2p/websockets": "^1.0.0",
    "libp2p": "^1.0.0",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "mongodb": "^6.3.0",
    "redis": "^4.6.12",
    "ws": "^8.16.0",
    "uuid": "^9.0.1",
    "axios": "^1.6.5",
    "tar": "^6.2.0"
  },
  "devDependencies": {
    "nodemon": "^3.0.2"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}